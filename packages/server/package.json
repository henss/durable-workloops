{
  "name": "@durable-workloops/server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "pnpm --filter @durable-workloops/api build && tsc -p tsconfig.build.json",
    "typecheck": "pnpm --filter @durable-workloops/api build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@durable-workloops/api": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "mongodb": "^7.0.0",
    "postgres": "^3.4.7",
    "fastify": "^5.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
