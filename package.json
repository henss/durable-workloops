{
  "name": "durable-workloops",
  "version": "0.1.0",
  "description": "Portable durable work-loop schemas and state transitions for agent workflows.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./selection": {
      "types": "./src/selection.ts",
      "import": "./src/selection.ts"
    },
    "./adjudication": {
      "types": "./src/adjudication.ts",
      "import": "./src/adjudication.ts"
    }
  },
  "scripts": {
    "atlas": "pnpm dlx @agent-atlas/cli@0.18.1",
    "atlas:doctor": "pnpm dlx @agent-atlas/cli@0.18.1 doctor --path . --profile public",
    "atlas:validate": "pnpm dlx @agent-atlas/cli@0.18.1 validate . --profile public",
    "atlas:boundary-check": "pnpm dlx @agent-atlas/cli@0.18.1 boundary-check . --profile public",
    "atlas:refresh": "pnpm dlx @agent-atlas/cli@0.18.1 maintain fix --path . --profile public",
    "atlas:check": "pnpm dlx @agent-atlas/cli@0.18.1 maintain check --path . --profile public",
    "atlas:docs:check": "pnpm dlx @agent-atlas/cli@0.18.1 generate markdown . --output docs/agents --profile public --check",
    "atlas:context-pack": "pnpm dlx @agent-atlas/cli@0.18.1 context-pack --path . --profile public",
    "atlas:resolve-path": "pnpm dlx @agent-atlas/cli@0.18.1 resolve-path --path . --profile public",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm atlas:check",
    "lint:docs": "node scripts/docs-quality-lint.mjs"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
